# vim: set ft=ruby:

search do
  prune_dirs /\A(\.svn|\.git|\.terraform|CVS|tmp|coverage|corpus|pkg|\.yardoc|doc)\z/
  skip_files /(\A\.|\.sw[pon]\z|\.(log|fnm|jpg|jpeg|png|pdf|svg)\z|\A(tags|cscope\.out)\z|~\z)/i
end

discover do
  prune_dirs /\A(\.svn|\.git|\.terraform|\.yardoc|CVS|tmp|coverage|corpus|pkg|\.yardoc|doc)\z/
  skip_files /(\A\.|\.sw[pon]\z|\.log\z|~\z)/
  index_expire_after 3_600
end

strip_spaces do
  prune_dirs /\A(\..*|CVS|pkg|\.yardoc)\z/
  skip_files /(\A\.|\.sw[pon]\z|\.log\z|~\z)/
end

probe do
  test_framework :rspec
end

ssh_tunnel do
  terminal_multiplexer :tmux
  login_session "/home/#{ENV['USER']}"
end

classify do
  shift_path_by_default 1
end

code_indexer do
  verbose false

  gems = %w[
    all_images
    amatch
    base64
    bigdecimal
    complex_config
    connection_pool
    date
    debug
    diff-lcs
    docile
    documentrix
    erb
    excon
    fileutils
    gem_hadar
    infobar
    io-console
    irb
    json
    kramdown
    kramdown-ansi
    kramdown-parser-gfm
    logger
    mize
    more_math
    net-http
    nokogiri
    numo-narray-alt
    ollama-ruby
    openssl
    ostruct
    pp
    prettyprint
    prism
    psych
    racc
    rake
    rdoc
    readline
    redis
    redis-client
    reline
    rexml
    rspec
    rspec-core
    rspec-expectations
    rspec-mocks
    rspec-support
    search_ui
    shellwords
    simplecov
    simplecov-html
    simplecov_json_formatter
    sqlite-vec
    sqlite3
    stringio
    sync
    term-ansicolor
    terminal-table
    tins
    tsort
    unicode-display_width
    unicode-emoji
    uri
    yaml
    yard
  ]

  paths {
    %w[ lib ] + gems.map { `bundle show #{it}` }.map(&:chomp)
  }
end
